<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= siteName %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <div class="shell">
    <aside class="sidebar">
      <h1><%= siteName %></h1>
      <p>Upload files, organize them into folders, and control who sees what.</p>

      <% if (user) { %>
        <div class="card">
          <h3>Welcome, <%= user.username %></h3>
          <p>Role: <strong><%= user.role %></strong></p>
          <p>Storage used: <strong><%= (storageStats && storageStats.used_bytes ? (storageStats.used_bytes / (1024 * 1024)).toFixed(2) : '0.00') %> MB</strong></p>
          <p>Files: <strong><%= storageStats && storageStats.file_count ? storageStats.file_count : 0 %></strong></p>
          <div class="actions">
            <a class="btn" href="/upload">Upload Files</a>
            <% if (user.role === 'admin') { %>
              <a class="btn secondary" href="/admin">Admin Dashboard</a>
            <% } %>
            <form method="post" action="/logout">
              <button type="submit">Logout</button>
            </form>
          </div>
        </div>
      <% } else { %>
        <div class="card">
          <a class="btn" href="/login">Login</a>
          <a class="btn secondary" href="/register">Create Account</a>
        </div>
      <% } %>
    </aside>

    <main class="content">
      <% if (error) { %>
        <div class="alert"><%= error %></div>
      <% } %>

      <% if (user) { %>
        <section class="card">
          <h2>New Folder</h2>
          <form method="post" action="/folders" class="inline-form">
            <input name="name" placeholder="Folder name" required />
            <% if (currentFolder) { %>
              <input type="hidden" name="parent_id" value="<%= currentFolder.id %>" />
            <% } %>
            <button type="submit">Create</button>
          </form>
        </section>
      <% } %>

      <section class="card">
        <div class="section-head">
          <h2>Folders</h2>
          <% if (parentFolder) { %>
            <a href="/?folder=<%= parentFolder.id %>">Back</a>
          <% } %>
        </div>

        <% if (folders.length === 0) { %>
          <p>No folders yet.</p>
        <% } else { %>
          <div class="grid">
            <% folders.forEach(folder => { %>
              <a class="item" href="/?folder=<%= folder.id %>">📁 <%= folder.name %></a>
            <% }) %>
          </div>
        <% } %>
      </section>

      <section class="card">
        <div class="section-head">
          <h2>Files</h2>
          <% if (user) { %>
            <a href="/upload">Upload</a>
          <% } %>
        </div>

        <% if (files.length === 0) { %>
          <p>No files in this folder.</p>
        <% } else { %>
          <div class="grid">
            <% files.forEach(file => { %>
              <div class="item file-item">
                <strong><%= file.title %></strong>
                <span><%= file.original_name %></span>
                <span>Visibility: <%= file.visibility %></span>
                <div class="mini-actions">
                  <a href="/files/<%= file.id %>">View</a>
                  <a href="/download/<%= file.id %>">Download</a>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </section>
    </main>
  </div>
</body>
</html>
