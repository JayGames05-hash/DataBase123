<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= siteName %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <div class="shell">
    <aside class="sidebar">
      <div class="brand">
        <div class="brand-mark">☁</div>
        <div>
          <h1><%= siteName %></h1>
          <p>Secure workspace</p>
        </div>
      </div>

      <% if (user) { %>
        <div class="profile-card">
          <div class="profile-header">
            <div class="avatar"><%= user.username.charAt(0).toUpperCase() %></div>
            <div>
              <h3><%= user.username %></h3>
              <p><%= user.role %></p>
            </div>
          </div>
          <div class="stats-grid">
            <div>
              <strong><%= (storageStats && storageStats.used_bytes ? (storageStats.used_bytes / (1024 * 1024)).toFixed(1) : '0.0') %> MB</strong>
              <span>Used</span>
            </div>
            <div>
              <strong><%= storageStats && storageStats.file_count ? storageStats.file_count : 0 %></strong>
              <span>Files</span>
            </div>
          </div>
          <div class="actions">
            <a class="btn primary" href="/upload">Upload</a>
            <% if (user.role === 'admin') { %>
              <a class="btn secondary" href="/admin">Admin</a>
            <% } %>
            <form method="post" action="/logout">
              <button type="submit">Sign out</button>
            </form>
          </div>
        </div>
      <% } else { %>
        <div class="profile-card">
          <p>Sign in to upload, organize, and manage your files in a polished private workspace.</p>
          <div class="actions">
            <a class="btn primary" href="/login">Login</a>
            <a class="btn secondary" href="/register">Create account</a>
          </div>
        </div>
      <% } %>
    </aside>

    <main class="content">
      <% if (error) { %>
        <div class="alert"><%= error %></div>
      <% } %>

      <% if (user) { %>
        <section class="hero-card">
          <div>
            <h2>Create a folder</h2>
            <p>Keep your workspace organized with folders for projects, clients, or media.</p>
          </div>
          <form method="post" action="/folders" class="inline-form">
            <input name="name" placeholder="Folder name" required />
            <% if (typeof currentFolder !== 'undefined' && currentFolder) { %>
              <input type="hidden" name="parent_id" value="<%= currentFolder.id %>" />
            <% } %>
            <button type="submit">Create folder</button>
          </form>
        </section>
      <% } %>

      <section class="panel">
        <div class="section-head">
          <div>
            <h2>Folders</h2>
            <p>Navigate your collections</p>
          </div>
          <% if (typeof parentFolder !== 'undefined' && parentFolder) { %>
            <a class="plain-link" href="/?folder=<%= parentFolder.id %>">Back</a>
          <% } %>
        </div>

        <% if (folders.length === 0) { %>
          <div class="empty-state">No folders yet. Create one to get started.</div>
        <% } else { %>
          <div class="grid">
            <% folders.forEach(folder => { %>
              <a class="item folder-item" href="/?folder=<%= folder.id %>">
                <div class="item-icon">📁</div>
                <strong><%= folder.name %></strong>
                <span>Open folder</span>
              </a>
            <% }) %>
          </div>
        <% } %>
      </section>

      <section class="panel">
        <div class="section-head">
          <div>
            <h2>Files</h2>
            <p>Recent uploads and accessible content</p>
          </div>
          <% if (user) { %>
            <a class="plain-link" href="/upload">Upload files</a>
          <% } %>
        </div>

        <% if (files.length === 0) { %>
          <div class="empty-state">No files in this folder yet.</div>
        <% } else { %>
          <div class="grid">
            <% files.forEach(file => { %>
              <div class="item file-item">
                <div class="item-icon">📄</div>
                <strong><%= file.title %></strong>
                <span><%= file.original_name %></span>
                <span class="muted">Visibility: <%= file.visibility %></span>
                <div class="mini-actions">
                  <a href="/files/<%= file.id %>">View</a>
                  <a href="/download/<%= file.id %>">Download</a>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </section>
    </main>
  </div>
</body>
</html>
