<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= siteName %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <div class="app-shell">
    <!-- Top Navigation Bar -->
    <div class="top-bar">
      <div class="top-bar-left">
        <div class="logo">
          <span class="logo-icon">☁</span>
          <span class="logo-text"><%= siteName %></span>
        </div>
      </div>
      <div class="top-bar-center">
        <div class="search-box">
          <input type="text" placeholder="Search your files" />
          <span class="search-icon">🔍</span>
        </div>
      </div>
      <div class="top-bar-right">
        <% if (user) { %>
          <div class="user-menu">
            <div class="avatar-small"><%= user.username.charAt(0).toUpperCase() %></div>
            <div class="user-info">
              <span class="user-name"><%= user.username %></span>
              <form method="post" action="/logout" class="logout-form">
                <button type="submit">Sign out</button>
              </form>
            </div>
          </div>
        <% } else { %>
          <a href="/login" class="btn-small">Login</a>
          <a href="/register" class="btn-small">Sign up</a>
        <% } %>
      </div>
    </div>

    <div class="main-layout">
      <%
        var isHomeActive = !sort || sort === 'home';
        var isRecentActive = sort === 'recent';
        var isSharedActive = sort === 'shared';
        var isAllActive = !type || type === 'all';
        var isDocActive = type === 'doc';
        var isImageActive = type === 'image';
      %>
      <!-- Left Sidebar Navigation -->
      <aside class="sidebar-nav">
        <div class="nav-section">
          <a href="/" class="nav-item <% if(isHomeActive) { %>active<% } %>">🏠 Home</a>
          <a href="/?sort=recent" class="nav-item <% if(isRecentActive) { %>active<% } %>">⏱ Recent</a>
          <a href="/?sort=shared" class="nav-item <% if(isSharedActive) { %>active<% } %>">👥 Shared</a>
        </div>
        
        <div class="nav-section">
          <div class="nav-label">Browse by</div>
          <a href="/?type=all" class="nav-item <% if(isAllActive) { %>active<% } %>">📋 All</a>
          <a href="/?type=doc" class="nav-item <% if(isDocActive) { %>active<% } %>">📄 Documents</a>
          <a href="/?type=image" class="nav-item <% if(isImageActive) { %>active<% } %>">🖼 Images</a>
        </div>

        <div class="nav-section" style="margin-top: 24px; padding-top: 16px; border-top: 1px solid #e5e5e5;">
          <% if (user) { %>
            <a href="/upload" class="btn-primary">+ Add new</a>
            <% if (user.role === 'admin') { %>
              <a href="/admin" class="nav-item">⚙ Admin</a>
            <% } %>
          <% } %>
        </div>
      </aside>

      <!-- Main Content Area -->
      <main class="content-area">
        <% if (error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>

        <% if (user && currentFolder) { %>
          <div class="breadcrumb">
            <a href="/">My files</a>
            <span class="sep">›</span>
            <span class="current"><%= currentFolder.name %></span>
          </div>
        <% } %>

        <!-- For You Section (Recommendations) -->
        <% if (user && !currentFolder) { %>
          <section class="for-you-section">
            <div class="for-you-header">
              <div>
                <h2>For you</h2>
                <p>Quick access to your key files</p>
              </div>
              <div class="create-form">
                <form method="post" action="/folders" class="quick-form">
                  <input type="text" name="name" placeholder="New folder name" required />
                  <button type="submit">Create folder</button>
                </form>
              </div>
            </div>
            <div class="for-you-grid">
              <% if (folders && folders.length > 0) { %>
                <% folders.slice(0, 6).forEach(folder => { %>
                  <a href="/?folder=<%= folder.id %>" class="rec-card">
                    <div class="rec-icon">📁</div>
                    <div class="rec-name"><%= folder.name %></div>
                  </a>
                <% }) %>
              <% } %>
              <% if (files && files.length > 0) { %>
                <% files.slice(0, Math.max(0, 6 - (folders ? folders.length : 0))).forEach(file => { %>
                  <a href="/files/<%= file.id %>" class="rec-card">
                    <div class="rec-icon">📄</div>
                    <div class="rec-name"><%= file.title %></div>
                  </a>
                <% }) %>
              <% } %>
            </div>
          </section>
        <% } %>

        <!-- Files List -->
        <section class="files-section">
          <div class="section-header">
            <div>
              <h3><%= currentFolder ? currentFolder.name : 'All files' %></h3>
              <p class="filter-indicator">
                <% if (sort === 'recent') { %>Recent uploads<% } %>
                <% if (sort === 'shared') { %>Shared with you<% } %>
                <% if (type === 'doc') { %>Documents only<% } %>
                <% if (type === 'image') { %>Images only<% } %>
              </p>
            </div>
            <% if (user) { %>
              <a href="/upload" class="link-action">Upload files</a>
            <% } %>
          </div>

          <% if (folders && folders.length > 0) { %>
            <div class="list-section">
              <h4 class="list-title">Folders</h4>
              <div class="items-list">
                <% folders.forEach(folder => { %>
                  <a href="/?folder=<%= folder.id %>" class="list-item">
                    <div class="item-icon">📁</div>
                    <div class="item-name"><%= folder.name %></div>
                  </a>
                <% }) %>
              </div>
            </div>
          <% } %>

          <% if (files && files.length > 0) { %>
            <div class="list-section">
              <h4 class="list-title">Files</h4>
              <div class="files-table">
                <div class="table-header">
                  <div class="col-name">Name</div>
                  <div class="col-modified">Modified</div>
                  <div class="col-owner">Owner</div>
                  <div class="col-size">Size</div>
                  <div class="col-actions">Actions</div>
                </div>
                <% files.forEach(file => { %>
                  <div class="table-row">
                    <div class="col-name">
                      <span class="file-icon">📄</span>
                      <span><%= file.title %></span>
                    </div>
                    <div class="col-modified"><%= new Date(file.created_at).toLocaleDateString() %></div>
                    <div class="col-owner"><%= file.owner_name %></div>
                    <div class="col-size"><%= (file.size / 1024).toFixed(1) %> KB</div>
                    <div class="col-actions">
                      <a href="/files/<%= file.id %>" class="action-link">View</a>
                      <a href="/download/<%= file.id %>" class="action-link">Download</a>
                      <% if (user && file.owner_id === user.id) { %>
                        <a href="javascript:shareFile(<%= file.id %>, '<%= file.title %>')" class="action-link">Share</a>
                      <% } %>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
          <% } %>

          <% if ((!folders || folders.length === 0) && (!files || files.length === 0)) { %>
            <div class="empty-state">
              <div class="empty-icon">📭</div>
              <h3>Nothing here yet</h3>
              <p><% if (user) { %>Create a folder or upload files to get started.<% } else { %>Sign in to see your files.<% } %></p>
            </div>
          <% } %>
        </section>
      </main>
    </div>
  </div>

  <!-- Share Modal -->
  <div id="shareModal" class="modal" style="display:none;">
    <div class="modal-content">
      <div class="modal-header">
        <h2 id="shareTitle">Share File</h2>
        <span class="modal-close" onclick="closeShareModal()">&times;</span>
      </div>
      <div class="modal-body">
        <div class="share-option">
          <label>Make it Public:</label>
          <button onclick="toggleVisibility('public')" class="btn-toggle">Public Link</button>
          <button onclick="toggleVisibility('private')" class="btn-toggle">Private</button>
        </div>
        <div class="share-option">
          <label>Share with Email:</label>
          <div class="share-form">
            <input type="email" id="shareEmail" placeholder="user@example.com" />
            <button onclick="shareWithUser()">Share</button>
          </div>
        </div>
        <div id="sharesList" class="shares-list"></div>
      </div>
    </div>
  </div>

  <script>
    let currentFileId = null;
    
    function shareFile(fileId, fileName) {
      currentFileId = fileId;
      document.getElementById('shareTitle').textContent = 'Share: ' + fileName;
      document.getElementById('shareModal').style.display = 'flex';
      loadShares();
    }
    
    function closeShareModal() {
      document.getElementById('shareModal').style.display = 'none';
      currentFileId = null;
    }
    
    function toggleVisibility(visibility) {
      fetch('/share/' + currentFileId, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'visibility=' + visibility
      })
      .then(r => r.json())
      .then(data => {
        alert('File is now ' + visibility);
        loadShares();
      })
      .catch(e => alert('Error: ' + e));
    }
    
    function shareWithUser() {
      const email = document.getElementById('shareEmail').value;
      if (!email) return alert('Enter an email');
      
      fetch('/share/' + currentFileId, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'email=' + encodeURIComponent(email)
      })
      .then(r => r.json())
      .then(data => {
        if (data.error) return alert('Error: ' + data.error);
        document.getElementById('shareEmail').value = '';
        alert('Shared successfully!');
        loadShares();
      })
      .catch(e => alert('Error: ' + e));
    }
    
    function loadShares() {
      fetch('/file/' + currentFileId + '/shares')
      .then(r => r.json())
      .then(data => {
        let html = '<div class="share-status">Visibility: <strong>' + data.visibility + '</strong></div>';
        if (data.shares && data.shares.length > 0) {
          html += '<div class="share-list-title">Shared with:</div>';
          data.shares.forEach(share => {
            html += '<div class="share-item">' + share.email + ' (' + share.username + ')</div>';
          });
        }
        document.getElementById('sharesList').innerHTML = html;
      })
      .catch(e => console.error(e));
    }
    
    window.onclick = function(event) {
      const modal = document.getElementById('shareModal');
      if (event.target == modal) modal.style.display = 'none';
    }
  </script>
</body>
</html>
