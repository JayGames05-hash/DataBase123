<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= file.title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <main>
    <h1><%= file.title %></h1>
    <p>Owner: <%= file.owner_name %></p>
    <p>Original name: <%= file.original_name %></p>
    <p>Visibility: <%= file.visibility %></p>
    <p>Type: <%= file.mime_type %></p>
    <p><a href="/download/<%= file.id %>">Download</a></p>
    <p><a href="/">Back</a></p>
  </main>
</body>
</html>
